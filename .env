# Строка подключения к базе данных (PostgreSQL DSN)
DATABASE_URI=postgresql://gmart:gmart_pswd@localhost:5550/gmart

# Запуск миграций
RUN_MIGRATIONS=true

# Адрес запуска HTTP-сервера (формат host:port)
RUN_ADDRESS=:8090

# Адрес внешней системы расчета баллов (формат host:port)
ACCRUAL_SYSTEM_ADDRESS=localhost:8099

# Авторизация
JWT_SECRET_KEY=SecretForJWTSecretForJWTSecretForJWT
JWT_TTL=15m
SESSION_TTL=100000h

# Воркеры
ACCRUAL_WORKERS=3